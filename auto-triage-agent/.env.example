# Auto-Triage Agent — environment configuration template.
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# The Config_Loader validates that every required variable below is present at
# startup and fails fast (exit non-zero) naming any missing variable by key.

# GitHub token used to push the hotfix branch and open the Pull Request.
# Requires repo scope on the single target repository.
GITHUB_TOKEN=

# Slack Incoming Webhook URL for the #qa channel (Block Kit alerts).
SLACK_WEBHOOK_URL=

# API key used to authenticate the headless Kiro CLI child process.
KIRO_API_KEY=

# HTTPS clone/remote URL of the single target repository the agent operates on.
REPO_URL=

# Shared secret used to authenticate inbound /webhook requests via HMAC.
WEBHOOK_SECRET=

# Maximum time (milliseconds) a Kiro triage run may take before it is killed.
KIRO_TIMEOUT_MS=120000

# Port the Express webhook server listens on.
PORT=3000
